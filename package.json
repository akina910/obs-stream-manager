{
  "name": "obs-stream-manager",
  "version": "0.2.0",
  "private": false,
  "description": "Local-first OBS dock for managing game profiles, multistream setup, recording and chat.",
  "author": "OBS Stream Manager contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/akina910/obs-stream-manager.git"
  },
  "type": "module",
  "main": "dist/desktop/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "oauth:configure": "tsx server/configure-oauth.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.server.json && vite build && npm run build:desktop && npm run prepare:provider",
    "build:desktop": "tsc -p tsconfig.desktop.json",
    "prepare:provider": "node scripts/prepare-provider-bundle.mjs",
    "dist:win": "npm run build && electron-builder --win nsis portable zip --x64 --publish never",
    "dist:win:dir": "npm run build && electron-builder --win dir --x64",
    "verify:package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows-package.ps1",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.desktop.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^9.3.0",
    "@napi-rs/keyring": "^1.3.0",
    "fastify": "^5.6.2",
    "lucide-react": "^0.548.0",
    "obs-websocket-js": "^5.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^4.0.7"
  }
}
