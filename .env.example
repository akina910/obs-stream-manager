# Optional: overrides the OS-specific data directory.
# OBS_STREAM_MANAGER_DATA_DIR=C:\\Users\\you\\AppData\\Roaming\\obs-stream-manager
PORT=4317

# Maintainer/release provisioning only. End users do not set these values.
# Preferred release bootstrap:
# OBS_STREAM_MANAGER_PROVIDER_OAUTH_FILE=C:\temporary\provider-oauth.json
# Alternative local maintainer setup for `npm run oauth:configure`:
# OBS_STREAM_MANAGER_GOOGLE_CLIENT_JSON=C:\path\to\desktop-client.json
# OBS_STREAM_MANAGER_YOUTUBE_CLIENT_ID=
# OBS_STREAM_MANAGER_TWITCH_CLIENT_ID=

